# OpenAI (default provider)
OPENAI_API_KEY=

# Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-3-5-sonnet-20241022

# --- Microsoft Fara-7B (computer-use agent) ---

# Recommended for 8–12GB VRAM: Ollama + Q4 quantized model (~6GB)
# LLM_PROVIDER=fara
# LLM_BACKEND=ollama
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=maternion/fara:7b
# FARA_MAX_ROUNDS=15

# 16GB+ VRAM: vLLM with reduced context
# LLM_PROVIDER=fara
# LLM_BACKEND=vllm
# LLM_BASE_URL=http://127.0.0.1:5000/v1
# LLM_MODEL=microsoft/Fara-7B
# FARA_MAX_ROUNDS=15
